<Window x:Class="CyberSecurity_Part2._2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CyberSecurity_Part2._2"
        mc:Ignorable="d"
        Title="Cyber Times — AI Assistant"
        WindowState="Maximized"
        Background="#0A0E1A"
        FontFamily="Segoe UI">

    <Window.Resources>

        <SolidColorBrush x:Key="BackgroundBrush"    Color="#0A0E1A" />
        <SolidColorBrush x:Key="PanelBrush"         Color="#0D1117" />
        <SolidColorBrush x:Key="CardBrush"          Color="#111827" />
        <SolidColorBrush x:Key="AccentBrush"        Color="#00FF9C" />
        <SolidColorBrush x:Key="AccentDimBrush"     Color="#00CC7A" />
        <SolidColorBrush x:Key="AccentHoverBrush"   Color="#1A00FF9C" />
        <SolidColorBrush x:Key="BotBrush"           Color="#0F2A1A" />
        <SolidColorBrush x:Key="UserBrush"          Color="#0A1628" />
        <SolidColorBrush x:Key="TextBrush"          Color="#E2E8F0" />
        <SolidColorBrush x:Key="MutedBrush"         Color="#64748B" />
        <SolidColorBrush x:Key="BorderBrush"        Color="#1E2D3D" />
        <SolidColorBrush x:Key="GlowBrush"          Color="#00FF9C" />

        <Style x:Key="SidebarButton" TargetType="Button">
            <Setter Property="Foreground"               Value="{StaticResource TextBrush}" />
            <Setter Property="Background"               Value="Transparent" />
            <Setter Property="BorderBrush"              Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness"          Value="1" />
            <Setter Property="Padding"                  Value="10" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="FontSize"                 Value="12" />
            <Setter Property="Cursor"                   Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="8,6">
                            <ContentPresenter VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"    Value="#0D1F14" />
                                <Setter TargetName="bd" Property="BorderBrush"   Value="{StaticResource AccentBrush}" />
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF9C" BlurRadius="8" ShadowDepth="0" Opacity="0.35" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00FF9C22" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Task item button style (complete/delete) -->
        <Style x:Key="TaskActionButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Foreground"      Value="{StaticResource MutedBrush}" />
            <Setter Property="FontSize"        Value="11" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Padding"         Value="6,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"  Value="#0D1F14" />
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00FF9C22" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="ChatMessageTemplate" DataType="{x:Type local:ChatMessage}">
            <Grid Margin="4,8">

                <StackPanel x:Name="BotLayout" Orientation="Vertical" HorizontalAlignment="Left" MaxWidth="720">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Border Width="28" Height="28"
                                Background="#0D1F14"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="#00FF9C" BlurRadius="8" ShadowDepth="0" Opacity="0.6" />
                            </Border.Effect>
                            <TextBlock Text="🛡"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="CyberSecurity - Times AI Assistant"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="8,0,0,0" />
                    </StackPanel>

                    <Border Background="{StaticResource BotBrush}"
                            BorderBrush="#00FF9C44"
                            BorderThickness="1"
                            CornerRadius="0,12,12,12"
                            Padding="14,10"
                            Margin="36,0,0,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.35" />
                        </Border.Effect>
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="13"
                                   LineHeight="20"
                                   FontWeight="Normal" />
                    </Border>
                </StackPanel>

                <StackPanel x:Name="UserLayout" Orientation="Vertical" HorizontalAlignment="Right" MaxWidth="720">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsUser}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="0,0,0,4">
                        <TextBlock Text="{Binding Sender}"
                                   Foreground="#3B82F6"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <Border Width="28" Height="28"
                                Background="#0A1628"
                                BorderBrush="#3B82F6"
                                BorderThickness="1"
                                CornerRadius="14">
                            <Border.Effect>
                                <DropShadowEffect Color="#3B82F6" BlurRadius="8" ShadowDepth="0" Opacity="0.6" />
                            </Border.Effect>
                            <TextBlock Text="👤"
                                       FontSize="13"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                    </StackPanel>

                    <Border Background="{StaticResource UserBrush}"
                            BorderBrush="#3B82F644"
                            BorderThickness="1"
                            CornerRadius="12,0,12,12"
                            Padding="14,10"
                            Margin="0,0,36,0">
                        <Border.Effect>
                            <DropShadowEffect Color="#000000" BlurRadius="8" ShadowDepth="1" Opacity="0.35" />
                        </Border.Effect>
                        <TextBlock Text="{Binding Text}"
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="13"
                                   LineHeight="20"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>

            </Grid>
        </DataTemplate>

        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Background"       Value="Transparent" />
            <Setter Property="BorderBrush"      Value="{StaticResource AccentBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Foreground"       Value="{StaticResource AccentBrush}" />
            <Setter Property="FontSize"         Value="12" />
            <Setter Property="FontWeight"       Value="SemiBold" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Padding"          Value="14,7" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00FF9C22" />
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF9C" BlurRadius="10" ShadowDepth="0" Opacity="0.5" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#00FF9C44" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RoundActionButton" TargetType="Button">
            <Setter Property="Width"            Value="48" />
            <Setter Property="Height"           Value="48" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="FontSize"         Value="18" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="24">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#00FF9C" BlurRadius="14" ShadowDepth="0" Opacity="0.6" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid x:Name="MainContentGrid" Margin="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="70" />
            <RowDefinition Height="*" />
            <RowDefinition Height="80" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <!-- Left sidebar (topics) -->
            <ColumnDefinition x:Name="SidebarColumn" Width="240" />
            <!-- Chat area -->
            <ColumnDefinition Width="*" />
            <!-- Right task panel -->
            <ColumnDefinition x:Name="TaskPanelColumn" Width="280" />
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════════════
             TOP HEADER
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="18,0">
            <Border.Effect>
                <DropShadowEffect Color="#00FF9C" BlurRadius="20" ShadowDepth="0" Opacity="0.08" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- LEFT: shield logo + brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="42" Height="42"
                            Background="#0D1F14"
                            BorderBrush="{StaticResource AccentBrush}"
                            BorderThickness="1"
                            CornerRadius="8">
                        <Border.Effect>
                            <DropShadowEffect Color="#00FF9C" BlurRadius="12" ShadowDepth="0" Opacity="0.6" />
                        </Border.Effect>
                        <TextBlock Text="🛡" FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="10,0,0,0">
                        <TextBlock Text="CYBER TIMES"
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="Bold" FontSize="13" />
                        <TextBlock Text="AI CYBERSECURITY"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontSize="10" />
                    </StackPanel>
                </StackPanel>

                <!-- CENTER: main title -->
                <StackPanel Grid.Column="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                    <TextBlock Text="CYBER TIMES WITH ABO"
                               Foreground="White"
                               FontWeight="Bold" FontSize="20"
                               TextAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00FF9C" BlurRadius="16" ShadowDepth="0" Opacity="0.5" />
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="AI Cybersecurity Assistant"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="11" TextAlignment="Center"
                               Opacity="0.85" />
                </StackPanel>

                <!-- RIGHT: status + username + End Chat + Start Quiz + Topics + Tasks toggle -->
                <StackPanel Grid.Column="2"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <StackPanel Orientation="Vertical"
                                VerticalAlignment="Center"
                                Margin="0,0,14,0">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Ellipse Width="7" Height="7" Fill="#00FF9C"
                                     VerticalAlignment="Center" Margin="0,0,5,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect Color="#00FF9C" BlurRadius="6" ShadowDepth="0" Opacity="0.9" />
                                </Ellipse.Effect>
                            </Ellipse>
                            <TextBlock Text="Status: Online"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontSize="11" />
                        </StackPanel>
                        <TextBlock x:Name="HeaderUserText"
                                   Text="User: "
                                   Foreground="{StaticResource TextBrush}"
                                   FontWeight="SemiBold"
                                   FontSize="11"
                                   HorizontalAlignment="Right" />
                    </StackPanel>

                    <!-- End Chat -->
                    <Button x:Name="EndChatButton"
                            Content="⏻  End Chat"
                            Style="{StaticResource HeaderButton}"
                            Visibility="Hidden"
                            Margin="0,0,10,0"
                            Click="EndChatButton_Click" />

                    <!-- Start Quiz — moved from sidebar to header -->
                    <Button x:Name="BtnStartQuiz"
                            Style="{StaticResource HeaderButton}"
                            Margin="0,0,10,0"
                            Click="BtnStartQuiz_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="🎮"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Start Quiz"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Topics toggle -->
                    <Button x:Name="BtnToggleTopics"
                            Style="{StaticResource HeaderButton}"
                            Width="110"
                            Margin="0,0,10,0"
                            Click="BtnToggleTopics_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="ToggleIcon" Text="☰"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Topics"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Button>

                    <!-- Tasks panel toggle -->
                    <Button x:Name="BtnToggleTasks"
                            Style="{StaticResource HeaderButton}"
                            Width="110"
                            Click="BtnToggleTasks_Click">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock x:Name="TaskToggleIcon" Text="📋"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,0,6,0" />
                            <TextBlock Text="Tasks"
                                       Foreground="{StaticResource AccentBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             LEFT SIDEBAR (Topics)
             ═══════════════════════════════════════════════════ -->
        <Border x:Name="Sidebar"
                Grid.Row="1" Grid.Column="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,1,0"
                Padding="12,14">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- TOPICS label + My Tasks + Activity Log + divider -->
                <StackPanel Grid.Row="0" Margin="0,0,0,8">

                    <StackPanel Orientation="Horizontal" Margin="4,0,0,10">
                        <TextBlock Text="▋" Foreground="{StaticResource AccentBrush}" FontSize="16" Margin="0,0,6,0" />
                        <TextBlock Text="TOPICS"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="11" />
                    </StackPanel>

                    <Button x:Name="BtnShowTasks"
                            Style="{StaticResource SidebarButton}"
                            Margin="0,4,0,0"
                            Click="BtnShowTasks_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="13" />
                            <TextBlock Text="My Tasks" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                        </StackPanel>
                    </Button>

                    <Button x:Name="BtnActivityLog"
                            Style="{StaticResource SidebarButton}"
                            Margin="0,4,0,0"
                            Click="BtnActivityLog_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜" FontSize="13" />
                            <TextBlock Text="Activity Log" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                        </StackPanel>
                    </Button>

                    <Border Height="1"
                            Background="{StaticResource BorderBrush}"
                            Margin="4,10,4,6" />
                </StackPanel>

                <!-- Scrollable topic buttons -->
                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <StackPanel>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="password" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" FontSize="13" />
                                <TextBlock Text="Password Security" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="phishing" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📧" FontSize="13" />
                                <TextBlock Text="Phishing" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="malware" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🛡️" FontSize="13" />
                                <TextBlock Text="Malware" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="social engineering" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎭" FontSize="13" />
                                <TextBlock Text="Social Engineering" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="2fa" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔒" FontSize="13" />
                                <TextBlock Text="Two-Factor Authentication" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="safe browsing" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🌐" FontSize="13" />
                                <TextBlock Text="Safe Browsing" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="ransomware" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💣" FontSize="13" />
                                <TextBlock Text="Ransomware" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="public wifi" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📶" FontSize="13" />
                                <TextBlock Text="Public Wi-Fi" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="identity theft" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🕵️" FontSize="13" />
                                <TextBlock Text="Identity Theft" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="updates" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⬆️" FontSize="13" />
                                <TextBlock Text="Software Updates" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="encryption" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔑" FontSize="13" />
                                <TextBlock Text="Encryption" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="firewalls" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧱" FontSize="13" />
                                <TextBlock Text="Firewalls" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="backup &amp; recovery" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💾" FontSize="13" />
                                <TextBlock Text="Backup &amp; Recovery" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="incident response" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🚨" FontSize="13" />
                                <TextBlock Text="Incident Response" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="privacy settings" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔐" FontSize="13" />
                                <TextBlock Text="Privacy Settings" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="iot security" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📡" FontSize="13" />
                                <TextBlock Text="IoT Security" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="mobile security" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📱" FontSize="13" />
                                <TextBlock Text="Mobile Security" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="secure coding" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="💻" FontSize="13" />
                                <TextBlock Text="Secure Coding" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="network segmentation" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🕸️" FontSize="13" />
                                <TextBlock Text="Network Segmentation" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="access control" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔒" FontSize="13" />
                                <TextBlock Text="Access Control" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarButton}" Margin="0,4,0,0" Tag="security policies" Click="TopicButton_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📜" FontSize="13" />
                                <TextBlock Text="Security Policies" Foreground="{StaticResource TextBrush}" Margin="10,0,0,0" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             CHAT AREA
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="1"
                Background="{StaticResource CardBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0"
                Margin="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <ListBox x:Name="ChatListBox"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource TextBrush}"
                         HorizontalContentAlignment="Stretch"
                         ItemTemplate="{StaticResource ChatMessageTemplate}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         Padding="12,8" />
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             RIGHT TASK PANEL
             ═══════════════════════════════════════════════════ -->
        <Border x:Name="TaskPanel"
                Grid.Row="1" Grid.Column="2"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1,0,0,0"
                Padding="12,14">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Header -->
                    <RowDefinition Height="Auto" />
                    <!-- Add task input row -->
                    <RowDefinition Height="Auto" />
                    <!-- Task list -->
                    <RowDefinition Height="*" />
                    <!-- Footer counts -->
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Panel header -->
                <StackPanel Grid.Row="0" Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal" Margin="4,0,0,6">
                        <TextBlock Text="▋" Foreground="{StaticResource AccentBrush}" FontSize="16" Margin="0,0,6,0" />
                        <TextBlock Text="MY TASKS"
                                   Foreground="{StaticResource AccentBrush}"
                                   FontWeight="Bold"
                                   FontSize="11" />
                        <TextBlock x:Name="TaskCountBadge"
                                   Text="  (0)"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                    <Border Height="1" Background="{StaticResource BorderBrush}" Margin="4,4,4,0" />
                </StackPanel>

                <!-- Quick-add task input -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0"
                            Background="#0D1117"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Margin="0,0,6,0">
                        <TextBox x:Name="QuickAddTaskBox"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderThickness="0"
                                 Padding="8,4"
                                 FontSize="12"
                                 CaretBrush="{StaticResource AccentBrush}"
                                 KeyDown="QuickAddTaskBox_KeyDown" />
                    </Border>
                    <Button Grid.Column="1"
                            x:Name="QuickAddTaskBtn"
                            Content="+"
                            Width="32" Height="32"
                            Background="{StaticResource AccentBrush}"
                            Foreground="#0A0E1A"
                            FontWeight="Bold"
                            FontSize="16"
                            Cursor="Hand"
                            Click="QuickAddTaskBtn_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="bd"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="6">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentDimBrush}" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Placeholder text for empty task box -->

                <!-- Scrollable task list -->
                <ScrollViewer Grid.Row="2"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="TaskListPanel">
                        <!-- Task cards are added here dynamically from code-behind -->
                        <TextBlock x:Name="EmptyTasksText"
                                   Text="No tasks yet. Type above or chat: 'add task enable 2FA'"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   TextWrapping="Wrap"
                                   Margin="4,8,4,0" />
                    </StackPanel>
                </ScrollViewer>

                <!-- Footer: pending / completed count -->
                <Border Grid.Row="3"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="4,8,4,0"
                        Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock x:Name="PendingCountText"
                                   Text="⏳ 0 pending"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11"
                                   Margin="0,0,12,0" />
                        <TextBlock x:Name="CompletedCountText"
                                   Text="✅ 0 done"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="11" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             INPUT BAR
             ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Grid.ColumnSpan="3"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,12">
            <Border.Effect>
                <DropShadowEffect Color="#00FF9C" BlurRadius="20" ShadowDepth="0" Opacity="0.05" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="#0D1117"
                        BorderBrush="{StaticResource BorderBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Margin="0,0,10,0">
                    <DockPanel>
                        <TextBox x:Name="InputTextBox"
                                 Height="46"
                                 VerticalContentAlignment="Center"
                                 Background="Transparent"
                                 Foreground="{StaticResource TextBrush}"
                                 BorderThickness="0"
                                 Padding="14,10"
                                 FontSize="13"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 KeyDown="InputTextBox_KeyDown"
                                 CaretBrush="{StaticResource AccentBrush}" />
                        <TextBlock Text="Ask me about cybersecurity..."
                                   Foreground="{StaticResource MutedBrush}"
                                   Margin="16,0,0,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Text, ElementName=InputTextBox}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </DockPanel>
                </Border>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="RecordButton"
                            Style="{StaticResource RoundActionButton}"
                            Background="Transparent"
                            BorderBrush="{StaticResource AccentBrush}"
                            Foreground="{StaticResource AccentBrush}"
                            Margin="0,0,8,0"
                            Click="RecordButton_Click"
                            ToolTip="Click to start / stop recording">
                        🎤
                    </Button>
                    <Button x:Name="SendButton"
                            Style="{StaticResource RoundActionButton}"
                            Background="{StaticResource AccentBrush}"
                            BorderBrush="{StaticResource AccentBrush}"
                            Foreground="#0A0E1A"
                            Click="SendButton_Click">
                        ➤
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════
             STARTUP OVERLAY
             ═══════════════════════════════════════════════════ -->
        <Grid x:Name="StartupOverlay"
              Grid.Row="0" Grid.RowSpan="3"
              Grid.Column="0" Grid.ColumnSpan="3"
              Background="#E60A0E1A"
              IsHitTestVisible="True"
              Panel.ZIndex="100">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="14"
                        Padding="36,32"
                        Width="520">
                    <Border.Effect>
                        <DropShadowEffect Color="#00FF9C" BlurRadius="40" ShadowDepth="0" Opacity="0.25" />
                    </Border.Effect>
                    <StackPanel>
                        <Border Width="60" Height="60"
                                Background="#0D1F14"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,18">
                            <Border.Effect>
                                <DropShadowEffect Color="#00FF9C" BlurRadius="16" ShadowDepth="0" Opacity="0.7" />
                            </Border.Effect>
                            <TextBlock Text="🛡" FontSize="28"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>

                        <TextBlock Text="Welcome to Cyber Times"
                                   Foreground="{StaticResource TextBrush}"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#00FF9C" BlurRadius="14" ShadowDepth="0" Opacity="0.4" />
                            </TextBlock.Effect>
                        </TextBlock>

                        <TextBlock Text="Please enter your first and last name to continue"
                                   Foreground="{StaticResource MutedBrush}"
                                   FontSize="13"
                                   Margin="0,8,0,22"
                                   HorizontalAlignment="Center" />

                        <Border Background="#0D1117"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="8">
                            <TextBox x:Name="NameTextBox"
                                     Height="44"
                                     FontSize="14"
                                     Padding="12,10"
                                     Background="Transparent"
                                     Foreground="{StaticResource TextBrush}"
                                     BorderThickness="0"
                                     CaretBrush="{StaticResource AccentBrush}"
                                     TextChanged="NameTextBox_TextChanged_1" />
                        </Border>

                        <TextBlock x:Name="NameWarning"
                                   Text="⚠  Please enter your name."
                                   Foreground="#FF6B6B"
                                   Visibility="Collapsed"
                                   Margin="4,8,0,0"
                                   FontSize="12" />

                        <Button x:Name="ContinueButton"
                                Content="CONTINUE  ▶"
                                Width="160" Height="42"
                                Margin="0,22,0,0"
                                HorizontalAlignment="Right"
                                Background="{StaticResource AccentBrush}"
                                Foreground="#0A0E1A"
                                FontWeight="Bold"
                                FontSize="13"
                                Cursor="Hand"
                                Click="ContinueButton_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="bd"
                                            Background="{TemplateBinding Background}"
                                            CornerRadius="8"
                                            Padding="16,8">
                                        <Border.Effect>
                                            <DropShadowEffect Color="#00FF9C" BlurRadius="14" ShadowDepth="0" Opacity="0.5" />
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentDimBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsPressed" Value="True">
                                            <Setter TargetName="bd" Property="Background" Value="#009960" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

    </Grid>
</Window>
